HF_TOKEN=
HF_ENDPOINT=https://hf-mirror.com
# 禁用 XET 分块传输协议，强制走标准 HTTP（解决 cas-bridge.xethub.hf.co 超时）
HF_HUB_DISABLE_XET=1

# 选择训练使用的基础模型，对应 models/ 目录下的子目录名
# 可选值：Qwen2.5-3B | gemma-4-E2B-it | gemma-4-E4B-it
#SELECT_MODEL=Qwen2.5-3B
SELECT_MODEL=gemma-4-E2B-it

# 模型所属 HuggingFace 组织（本地模型不存在时用于远程下载）
# Qwen2.5-3B → Qwen    gemma-4-* → google
HF_MODEL_ORG=Qwen
